---
const pathname = Astro.url.pathname;

const tabs = [
	{
		id: 'overview',
		label: 'Overview',
		href: '/it/',
		isActive: (p: string) => p === '/it' || p === '/it/' || p.startsWith('/it/overview'),
		icon: `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
	},
	{
		id: 'dev',
		label: 'Dev',
		href: '/it/programming/',
		isActive: (p: string) => p.startsWith('/it/programming') || p.startsWith('/it/web'),
		icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
	},
	{
		id: 'security',
		label: 'Security',
		href: '/it/security/',
		isActive: (p: string) =>
			p.startsWith('/it/security') || p.startsWith('/it/auth') || p.startsWith('/it/network'),
		icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
	},
	{
		id: 'ai',
		label: 'AI',
		href: '/it/ai/',
		isActive: (p: string) => p.startsWith('/it/ai'),
		icon: `<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`,
	},
	{
		id: 'math',
		label: 'Math',
		href: '/it/math/',
		isActive: (p: string) => p.startsWith('/it/math'),
		icon: `<path d="M16 4 L4 4 L11 12 L4 20 L16 20" fill="none"/>`,
	},
	{
		id: 'infra',
		label: 'Infra',
		href: '/it/cloud/',
		isActive: (p: string) =>
			p.startsWith('/it/cloud') ||
			p.startsWith('/it/databases') ||
			p.startsWith('/it/os') ||
			p.startsWith('/it/tools'),
		icon: `<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
	},
];
---

<nav class="nav-tabs" aria-label="Site sections">
	<ul role="list">
		{tabs.map((tab) => {
			const active = tab.isActive(pathname);
			return (
				<li>
					<a
						href={tab.href}
						class:list={['nav-tab', { active }]}
						aria-current={active ? 'page' : undefined}
					>
						<span class="tab-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={tab.icon} />
						</span>
						<span>{tab.label}</span>
					</a>
				</li>
			);
		})}
	</ul>
</nav>

<style>
	.nav-tabs {
		padding: 0.625rem 0.75rem 0.875rem;
	}

	.nav-tabs ul {
		list-style: none;
		padding: 0.375rem;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.25rem;
		background-color: var(--sl-color-bg-nav);
		border-radius: 0.75rem;
	}

	.nav-tab {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.45rem 0.6rem;
		border-radius: 0.5rem;
		border: 1px solid transparent;
		font-size: var(--sl-text-sm);
		font-weight: 500;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		transition:
			background-color 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
		white-space: nowrap;
	}

	.nav-tab:hover:not(.active) {
		background-color: var(--sl-color-gray-6);
		color: var(--sl-color-white);
	}

	.nav-tab.active {
		border-color: var(--sl-color-accent);
		background-color: var(--sl-color-bg);
		color: var(--sl-color-white);
		font-weight: 600;
	}

	.tab-icon {
		display: flex;
		align-items: center;
		flex-shrink: 0;
		opacity: 0.8;
	}

	.nav-tab.active .tab-icon {
		opacity: 1;
		color: var(--sl-color-accent);
	}
</style>
